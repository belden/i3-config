#!/bin/bash

device=amdgpu_bl1

function refresh_i3_status() {
  killall -SIGUSR1 i3status 2> /dev/null
}

function get_brightness() {
  brightness=$(brightnessctl -d $device g)
  brightness=$(( $brightness * 100 ))
  max=$(brightnessctl -d $device m)
  amt=$(( $brightness / $max ))
  echo "$amt"
}

function set_brightness() {
  local mod=$1
  /usr/bin/brightnessctl -d $device set $mod > /dev/null 2>&1 && refresh_i3_status
}

function main() {
  local vol=$(get_brightness)

  case "$1" in
    up)
      if [[ "$vol" -le 99 ]]; then
        next=$(( $vol + 10 ))
        set_brightness "$next%"
      fi
      ;;
    down)
      if [[ "$vol" -ge 40 ]]; then
        next=$(( $vol - 10 ))
        set_brightness "$next%"
      fi
      ;;
    get)
      local vol=$(get_brightness)
      echo "$vol%"
      ;;
    min)
      set_brightness 30%
      ;;
    max|*)
      set_brightness 100%
      ;;
  esac
}

main "$@"
